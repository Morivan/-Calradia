# ── Django ────────────────────────────────────────────────────────────────────
# Генерируется командой:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# false — для продакшна; true — для локальной разработки
DJANGO_DEBUG=false

# Домен(ы) через запятую, например: example.com,www.example.com
DJANGO_ALLOWED_HOSTS=

# Полные URL через запятую (нужны при DJANGO_DEBUG=false)
CSRF_TRUSTED_ORIGINS=https://example.com
CORS_ALLOWED_ORIGINS=https://example.com

# ── Telegram bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_MANAGER_CHAT_ID=
TELEGRAM_CHANNEL_ID=@your_channel
TELEGRAM_PUBLIC_URL=https://t.me/your_channel

# ── VK Callback API ───────────────────────────────────────────────────────────
# Secret key — задаётся в настройках группы ВК → Работа с API → Callback API
VK_CALLBACK_SECRET=
# Строка подтверждения — выдаётся ВКонтакте при добавлении сервера
VK_CONFIRMATION_TOKEN=

# ── VK community links ────────────────────────────────────────────────────────
VK_COMMUNITY_URL=https://vk.com/calradia_band
VK_MESSAGES_URL=https://vk.com/im/convo/-234061306?entrypoint=community_page&tab=all

# ── Яндекс Формы webhook ──────────────────────────────────────────────────────
# Токен для защиты webhook-эндпоинтов от посторонних запросов.
# Генерируется командой: python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_TOKEN=

# ── Email-уведомления о горящих заказах ──────────────────────────────────────
# Хост SMTP-сервера. Примеры:
#   Яндекс Почта:  smtp.yandex.ru  (порт 465, SSL)
#   Gmail:         smtp.gmail.com  (порт 465, SSL)
#   Mail.ru:       smtp.mail.ru    (порт 465, SSL)
EMAIL_HOST=smtp.yandex.ru
EMAIL_PORT=465
EMAIL_USE_SSL=true
EMAIL_USE_TLS=false
# Логин почтового ящика, с которого уходят письма
EMAIL_HOST_USER=your@yandex.ru
# Пароль приложения (не основной пароль аккаунта!)
EMAIL_HOST_PASSWORD=
# Адрес в поле «От»; обычно совпадает с EMAIL_HOST_USER
DEFAULT_FROM_EMAIL=your@yandex.ru
# Почта администратора — получает все напоминания о горящих заказах
ADMIN_NOTIFICATION_EMAIL=admin@example.com

# ── Яндекс Диск (автообновление таблиц) ──────────────────────────────────────
# OAuth-токен: oauth.yandex.ru → новое приложение → права cloud_api:disk.readwrite
# Затем: https://oauth.yandex.ru/authorize?response_type=token&client_id=ТВОЙ_CLIENT_ID
YANDEX_DISK_TOKEN=
YANDEX_ORDERS_TABLE_PATH=/Калрадия/Заказы.xlsx
YANDEX_CLIENTS_TABLE_PATH=/Калрадия/Клиенты.xlsx
YANDEX_MATERIALS_TABLE_PATH=/Калрадия/Материалы.xlsx
YANDEX_COLLEAGUES_TABLE_PATH=/Калрадия/Коллеги.xlsx
